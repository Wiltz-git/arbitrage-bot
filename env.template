# ============================================================
# CRYPTO ARBITRAGE BOT - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual API credentials
# NEVER commit .env to version control!
# ============================================================

# ========================
# KRAKEN API CREDENTIALS
# ========================
# Get from: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here

# ========================
# COINBASE ADVANCED TRADE API (Ed25519)
# ========================
# Get from: https://www.coinbase.com/settings/api
# Format: organizations/{org_id}/apiKeys/{key_id}
COINBASE_API_KEY=organizations/your-org-id/apiKeys/your-key-id
# IMPORTANT: Keep the full PEM format with \n for line breaks
COINBASE_SECRET="-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END EC PRIVATE KEY-----\n"

# ========================
# BITSTAMP API CREDENTIALS
# ========================
# Get from: https://www.bitstamp.net/account/security/api/
BITSTAMP_API_KEY=your_bitstamp_api_key_here
BITSTAMP_SECRET=your_bitstamp_secret_here
# IMPORTANT: Your Bitstamp Customer ID (found in account settings)
BITSTAMP_CUSTOMER_ID=your_customer_id_here

# ========================
# CRYPTO.COM API CREDENTIALS
# ========================
# Get from: https://crypto.com/exchange/user/settings/api-management
# IMPORTANT: Whitelist your server IP address!
CRYPTOCOM_API_KEY=your_cryptocom_api_key_here
CRYPTOCOM_SECRET=your_cryptocom_secret_here

# ========================
# TRADING MODE
# ========================
# Set to 'true' for paper trading (simulation), 'false' for live trading
PAPER_TRADING_MODE=true

# Enable trade amount scaling based on balance growth
SCALING_ENABLED=false

# ========================
# EMAIL NOTIFICATIONS (Optional)
# ========================
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_email_app_password
RECIPIENT_EMAIL=your_email@example.com

# Demo mode flag (set to false for production)
DEMO_MODE=false

# ========================
# DASHBOARD SYNC CONFIGURATION
# ========================
# Enable syncing trade data to your remote dashboard
DASHBOARD_SYNC_ENABLED=true

# Your dashboard URL (the deployed Abacus.AI dashboard)
DASHBOARD_URL=https://crypto-arbitrage-das-bs7yse.abacusai.app

# API key for authenticating with the dashboard (keep this secret!)
DASHBOARD_SYNC_API_KEY=88288ef6359dc87d659b087fdcc78a8a3e155639d5a2758ed4d502440f36e426

# Sync timeout in seconds
DASHBOARD_SYNC_TIMEOUT=10
